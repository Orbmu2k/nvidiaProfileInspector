<Application
    x:Class="nvidiaProfileInspector.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:nvidiaProfileInspector.UI.Converters"
    ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Styles/Icons.xaml" />
                <ResourceDictionary Source="/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="/UI/Styles/Theme.xaml" />
                <ResourceDictionary Source="/UI/Styles/Snackbar.xaml" />
                <ResourceDictionary Source="/UI/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
