<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:nvidiaProfileInspector.UI.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/UI/Styles/Colors.xaml" />
        <ResourceDictionary Source="/UI/Styles/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="controls:SearchableTextBox">
        <Setter Property="Background" Value="{DynamicResource Layer2BackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SearchableTextBox">
                    <Grid>
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Margin="24,0,40,0"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    VerticalScrollBarVisibility="Disabled" />

                                <!--  Search Icon  -->
                                <Path
                                    x:Name="SearchIcon"
                                    Width="16"
                                    Height="16"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Data="{StaticResource IconSearch}"
                                    Fill="{DynamicResource TextDisabledBrush}"
                                    Stretch="Uniform" />

                                <!--  Placeholder  -->
                                <TextBlock
                                    x:Name="PlaceholderText"
                                    Margin="36,0"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextDisabledBrush}"
                                    IsHitTestVisible="False"
                                    Text="{TemplateBinding Placeholder}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <!--  Clear Button  -->
                        <Button
                            x:Name="PART_ClearButton"
                            Width="24"
                            Height="24"
                            Margin="0,0,6,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False"
                            Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="btnBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="12">
                                        <Path
                                            Width="8"
                                            Height="8"
                                            Data="M0,0 L8,8 M8,0 L0,8"
                                            Stroke="{DynamicResource TextSecondaryBrush}"
                                            StrokeEndLineCap="Round"
                                            StrokeStartLineCap="Round"
                                            StrokeThickness="1.5" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource NvidiaGreenBrush}" />
                            <Setter TargetName="border" Property="BorderThickness" Value="1.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
