<Window
    x:Class="nvidiaProfileInspector.UI.Views.Dialogs.BitEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:nvidiaProfileInspector.UI.Controls"
    xmlns:converters="clr-namespace:nvidiaProfileInspector.UI.Converters;assembly=nvidiaProfileInspector"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:nvidiaProfileInspector.UI.ViewModels"
    Title="Bit Value Editor"
    Width="1241"
    Height="860"
    MinHeight="620"
    MaxHeight="960"
    SizeToContent="Manual"
    Style="{StaticResource DarkDialogWindowStyle}"
    WindowStartupLocation="CenterOwner"
    d:DataContext="{x:Static vm:DesignTimeData.BitEditorViewModel}"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style
            x:Key="BitEditorListViewItemStyle"
            BasedOn="{StaticResource DarkListViewItemStyle}"
            TargetType="ListViewItem">
            <Setter Property="Padding" Value="{DynamicResource ListItemPadding}" />
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource Layer2BackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PressedOverlayBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="BitEditorGridHeaderStyle"
            TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Layer2BackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar (Draggable Area)  -->
        <Border
            Grid.Row="0"
            Padding="24,12,0,0"
            Background="Transparent">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="Bit Value Editor" />

                <StackPanel
                    Grid.Column="1"
                    Margin="0,-12,0,0"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button
                        Click="Close_Click"
                        Style="{StaticResource CloseWindowButtonStyle}"
                        ToolTip="Close">
                        <Path
                            Width="10"
                            Height="10"
                            Data="{StaticResource IconClose}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                FontSize="13"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Text="Inspect individual flag bits, compare them against scanned profiles, and quickly test the value in a game launch."
                TextWrapping="Wrap" />

            <controls:SearchableTextBox
                x:Name="FilterTextBox"
                Grid.Row="1"
                Margin="0,0,0,12"
                Placeholder="Filter profile names..."
                Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Filter scanned profile names" />

            <Grid Grid.Row="2" MinHeight="360">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    Padding="10,6"
                    Background="{DynamicResource NvidiaGreenBrush}"
                    BorderBrush="{DynamicResource NvidiaGreenPressedBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding HasMatchesAboveVisibleRange, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Path
                            Width="12"
                            Height="12"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Data="M 12 4 L 20 12 L 16 12 L 16 20 L 8 20 L 8 12 L 4 12 Z"
                            Fill="{DynamicResource TextOnAccentBrush}"
                            Stretch="Uniform" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            Text="{Binding MatchesAboveVisibleRange, StringFormat={}{0} matches above the visible area}" />
                    </StackPanel>
                </Border>

                <ListView
                    x:Name="BitsListView"
                    Grid.Row="1"
                    AlternationCount="2"
                    ItemsSource="{Binding FilteredBits}"
                    ItemContainerStyle="{StaticResource BitEditorListViewItemStyle}"
                    Loaded="BitsListView_Loaded"
                    MinHeight="360"
                    SelectionMode="Single"
                    SizeChanged="BitsListView_SizeChanged"
                    Style="{StaticResource DarkListViewStyle}">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource BitEditorGridHeaderStyle}">
                            <GridViewColumn Header="#">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BitLabel}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Enabled">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox
                                            HorizontalAlignment="Center"
                                            IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource DarkCheckBoxStyle}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Description">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MaskDescription}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Count">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProfileCount}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Profiles">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding VisibleProfileNames}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border
                    Grid.Row="2"
                    Margin="0,6,0,0"
                    Padding="10,6"
                    Background="{DynamicResource NvidiaGreenBrush}"
                    BorderBrush="{DynamicResource NvidiaGreenPressedBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding HasMatchesBelowVisibleRange, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Path
                            Width="12"
                            Height="12"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Data="M 8 4 L 16 4 L 16 12 L 20 12 L 12 20 L 4 12 L 8 12 Z"
                            Fill="{DynamicResource TextOnAccentBrush}"
                            Stretch="Uniform" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            Text="{Binding MatchesBelowVisibleRange, StringFormat={}{0} matches below the visible area}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid
                Grid.Row="3"
                Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="410" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="16"
                    Margin="0,0,8,0"
                    Background="{DynamicResource Layer2BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="Test Area" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Apply the edited value to the current profile, then optionally launch a game executable to test it immediately."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBox
                            x:Name="GamePathTextBox"
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,12,8,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource DarkTextBoxStyle}"
                            Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="Game executable path" />
                        <Button
                            Grid.Row="1"
                            Grid.Column="1"
                            MinWidth="96"
                            Margin="0,12,8,0"
                            Padding="12,6"
                            Click="Browse_Click"
                            Style="{StaticResource DarkButtonStyle}"
                            ToolTip="Browse for game executable">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Data="{DynamicResource IconFolder}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Stretch="Uniform" />
                                <TextBlock VerticalAlignment="Center" Text="Browse" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Row="1"
                            Grid.Column="2"
                            MinWidth="140"
                            Margin="0,12,0,0"
                            Padding="12,6"
                            Command="{Binding ApplyAndLaunchCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTip="Apply changes and launch game">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Data="{DynamicResource IconGame}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Stretch="Uniform" />
                                <TextBlock VerticalAlignment="Center" Text="Apply &amp; Launch" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="16"
                    Background="{DynamicResource Layer2BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.ColumnSpan="2"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="Current Value" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="Review and apply the current bitmask value." />
                        <Grid
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Value:" />
                            <TextBox
                                x:Name="CurrentValueTextBox"
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                IsReadOnly="True"
                                Style="{StaticResource DarkTextBoxStyle}"
                                Text="{Binding CurrentValueHex, Mode=OneWay}"
                                ToolTip="Current DWORD value" />
                            <Button
                                Grid.Column="2"
                                MinWidth="96"
                                Padding="12,6"
                                Command="{Binding ApplyCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTip="Apply bit changes">
                                <StackPanel Orientation="Horizontal">
                                    <Path
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Data="{DynamicResource IconApply}"
                                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Stretch="Uniform" />
                                    <TextBlock VerticalAlignment="Center" Text="Apply" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="3"
                                MinWidth="80"
                                Margin="8,0,0,0"
                                Padding="12,6"
                                Click="Close_Click"
                                Content="Close"
                                Style="{StaticResource DarkButtonStyle}"
                                ToolTip="Close without saving" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Row="4"
                Margin="0,8,0,0"
                FontSize="12"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Text="{Binding StatusMessage}" />
        </Grid>
    </Grid>
</Window>
