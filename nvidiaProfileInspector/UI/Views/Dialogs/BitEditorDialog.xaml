<Window
    x:Class="nvidiaProfileInspector.UI.Views.Dialogs.BitEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:nvidiaProfileInspector.UI.Converters;assembly=nvidiaProfileInspector"
    Title="Bit Value Editor"
    Width="812"
    Height="Auto"
    MinHeight="500"
    MaxHeight="900"
    SizeToContent="Height"
    Style="{StaticResource DarkDialogWindowStyle}"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar (Draggable Area)  -->
        <Border
            Grid.Row="0"
            Padding="24,12,0,0"
            Background="Transparent">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="Bit Value Editor" />

                <StackPanel
                    Grid.Column="1"
                    Margin="0,-12,0,0"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button
                        Click="Close_Click"
                        Style="{StaticResource CloseWindowButtonStyle}"
                        ToolTip="Close">
                        <Path
                            Width="10"
                            Height="10"
                            Data="{StaticResource IconClose}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,16"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="Current Value: " />
                <TextBox
                    x:Name="CurrentValueTextBox"
                    Width="150"
                    Margin="0,0,16,0"
                    IsReadOnly="True"
                    Style="{StaticResource DarkTextBoxStyle}" />
                <Button
                    MinWidth="80"
                    Padding="12,6"
                    Click="Apply_Click"
                    Content="Apply"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTip="Apply bit changes" />
                <Button
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Padding="12,6"
                    Click="Close_Click"
                    Content="Close"
                    Style="{StaticResource DarkButtonStyle}"
                    ToolTip="Close without saving" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="Filter: " />
                <TextBox
                    x:Name="FilterTextBox"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{StaticResource DarkTextBoxStyle}"
                    TextChanged="FilterTextBox_TextChanged"
                    ToolTip="Filter bit descriptions" />
            </Grid>

            <DataGrid
                x:Name="BitsDataGrid"
                Grid.Row="2"
                Height="350"
                AutoGenerateColumns="False"
                CanUserResizeRows="False"
                CellStyle="{StaticResource DarkDataGridCellStyle}"
                ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                IsReadOnly="True"
                SelectionMode="Single"
                Style="{StaticResource DarkDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="50"
                        Binding="{Binding BitLabel}"
                        Header="#" />
                    <DataGridTemplateColumn Width="80" Header="Enabled">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox
                                    HorizontalAlignment="Center"
                                    IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource DarkCheckBoxStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding MaskDescription}"
                        Header="Description" />
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding ProfileCount}"
                        Header="Count" />
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="Game Path: " />
                <TextBox
                    x:Name="GamePathTextBox"
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource DarkTextBoxStyle}"
                    ToolTip="Game executable path" />
                <Button
                    Grid.Column="2"
                    MinWidth="80"
                    Padding="12,6"
                    Click="Browse_Click"
                    Content="Browse"
                    Style="{StaticResource DarkButtonStyle}"
                    ToolTip="Browse for game executable" />
                <Button
                    Grid.Column="3"
                    MinWidth="120"
                    Margin="8,0,0,0"
                    Padding="12,6"
                    Click="ApplyLaunch_Click"
                    Content="Apply &amp; Launch"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTip="Apply changes and launch game" />
            </Grid>

            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Row="4"
                Margin="0,8,0,0"
                FontSize="12"
                Foreground="{DynamicResource TextSecondaryBrush}" />
        </Grid>
    </Grid>
</Window>
