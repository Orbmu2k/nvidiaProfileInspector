<Window
    x:Class="nvidiaProfileInspector.UI.Views.Dialogs.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:nvidiaProfileInspector.UI.ViewModels"
    Title="About NVIDIA PROFILE INSPECTOR"
    Width="820"
    Height="Auto"
    MinWidth="760"
    MinHeight="460"
    MaxWidth="900"
    MaxHeight="760"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Style="{StaticResource DarkDialogWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,12,0,0"
            Background="Transparent">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="About" />

                <StackPanel
                    Grid.Column="1"
                    Margin="0,-12,0,0"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button
                        Click="Close_Click"
                        Style="{StaticResource CloseWindowButtonStyle}"
                        ToolTip="Close">
                        <Path
                            Width="10"
                            Height="10"
                            Data="{StaticResource IconClose}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,24,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border
                    Padding="18"
                    Background="{DynamicResource Layer1BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Path
                            Width="52"
                            Height="52"
                            Margin="0,0,18,0"
                            Data="{DynamicResource IconInspectorApp}"
                            Fill="{DynamicResource NvidiaGreenBrush}"
                            Stretch="Uniform" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="NVIDIA PROFILE INSPECTOR" />
                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Version " />
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource NvidiaGreenBrush}"
                                    Text="{Binding Version}" />
                            </StackPanel>

                            <Button
                                Margin="0,10,0,0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Command="{Binding OpenGitHubRepositoryCommand}"
                                Style="{StaticResource LinkButtonStyle}"
                                ToolTip="Open GitHub repository">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Text="github.com/Orbmu2k/nvidiaProfileInspector"
                                    TextDecorations="Underline" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Margin="0,16,0,0"
                    Padding="18"
                    Background="{DynamicResource Layer1BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="UPDATES" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,14,8"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Channel" />
                            <ComboBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Height="32"
                                ItemsSource="{Binding UpdateChannels}"
                                SelectedItem="{Binding SelectedUpdateChannel, Mode=TwoWay}"
                                Style="{StaticResource DarkComboBoxStyle}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,10,14,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Latest" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{Binding LatestVersionText}" />
                        </Grid>

                        <CheckBox
                            Margin="0,16,0,0"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            IsChecked="{Binding IsAutomaticUpdateCheckEnabled}">
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="Check for available updates on startup" />
                        </CheckBox>

                        <Border
                            Margin="0,16,0,0"
                            Padding="12"
                            Background="{DynamicResource Layer2BackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path
                                    Width="18"
                                    Height="18"
                                    Margin="0,1,10,0"
                                    Data="{DynamicResource IconInfo}"
                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                    Stretch="Uniform" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Text="{Binding UpdateStatusText}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                            <Button
                                MinWidth="96"
                                Margin="0,0,8,0"
                                Command="{Binding CheckForUpdateCommand}"
                                Content="Check Now"
                                Style="{StaticResource DarkButtonStyle}" />
                            <Button
                                MinWidth="126"
                                Command="{Binding InstallUpdateCommand}"
                                Content="Install Update"
                                IsEnabled="{Binding CanInstallUpdate}"
                                Style="{StaticResource AccentButtonStyle}" />
                            <Button
                                MinWidth="96"
                                Margin="8,0,0,0"
                                Command="{Binding OpenGitHubCommand}"
                                Content="Releases"
                                Style="{StaticResource DarkButtonStyle}"
                                ToolTip="Open GitHub releases" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="CONTRIBUTORS" />

                <ScrollViewer
                    Grid.Row="1"
                    CanContentScroll="True"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Contributors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="10"
                                    Background="{DynamicResource Layer1BackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            Width="34"
                                            Height="34"
                                            Margin="0,0,10,0"
                                            Background="#333"
                                            CornerRadius="17">
                                            <Border ClipToBounds="True" CornerRadius="17">
                                                <Image
                                                    Width="34"
                                                    Height="34"
                                                    Source="{Binding AvatarUrl}"
                                                    Stretch="UniformToFill" />
                                            </Border>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="{Binding Name}" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Text="{Binding Role}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Button
                                            Grid.Column="2"
                                            Command="{Binding DataContext.OpenContributorProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ProfileUrl}"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="View Profile">
                                            <Path
                                                Width="16"
                                                Height="16"
                                                Data="{DynamicResource IconUser}"
                                                Fill="{DynamicResource TextSecondaryBrush}"
                                                Stretch="Uniform" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Padding="18"
                    Background="{DynamicResource Layer1BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="STARTUP" />

                        <CheckBox
                            Margin="0,12,0,0"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            IsChecked="{Binding IsSplashScreenDisabled}">
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="Disable splash screen on startup" />
                        </CheckBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="24"
            Background="{DynamicResource Layer2BackgroundBrush}"
            CornerRadius="0,0,8,8">
            <Button
                MinWidth="100"
                HorizontalAlignment="Right"
                Click="Close_Click"
                Content="Close"
                Style="{StaticResource AccentButtonStyle}" />
        </Border>
    </Grid>
</Window>
