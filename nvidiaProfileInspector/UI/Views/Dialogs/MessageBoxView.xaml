<Window
    x:Class="nvidiaProfileInspector.UI.Views.Dialogs.MessageBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Title}"
    Width="400"
    Height="Auto"
    MinWidth="350"
    MinHeight="150"
    MaxWidth="600"
    MaxHeight="600"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Style="{StaticResource DarkDialogWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar (Draggable Area)  -->
        <Border
            Grid.Row="0"
            Padding="24,12,0,0"
            Background="Transparent">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />

                <StackPanel
                    Grid.Column="1"
                    Margin="0,-12,0,0"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource CloseWindowButtonStyle}"
                        ToolTip="Close">
                        <Path
                            Width="10"
                            Height="10"
                            Data="{StaticResource IconClose}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Icon  -->
            <Path
                Grid.Column="0"
                Width="24"
                Height="24"
                Margin="0,4,16,0"
                VerticalAlignment="Top"
                Data="{Binding IconPath}"
                Fill="{Binding IconColor}"
                Stretch="Uniform"
                Visibility="{Binding IconVisibility}" />

            <!--  Message  -->
            <ScrollViewer
                Grid.Column="1"
                MaxHeight="400"
                VerticalScrollBarVisibility="Auto">
                <TextBlock
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    LineHeight="20"
                    Text="{Binding Message}"
                    TextWrapping="Wrap" />
            </ScrollViewer>
        </Grid>

        <!--  Footer / Buttons  -->
        <Border
            Grid.Row="2"
            Padding="24"
            Background="{DynamicResource Layer2BackgroundBrush}"
            CornerRadius="0,0,8,8">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <!--  OK Button  -->
                <Button
                    MinWidth="80"
                    Command="{Binding OKCommand}"
                    Content="OK"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTip="Confirm action"
                    Visibility="{Binding Buttons, Converter={StaticResource MessageBoxButtonToVisibilityConverter}, ConverterParameter=OK}" />

                <!--  Yes Button  -->
                <Button
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Command="{Binding YesCommand}"
                    Content="Yes"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTip="Confirm yes"
                    Visibility="{Binding Buttons, Converter={StaticResource MessageBoxButtonToVisibilityConverter}, ConverterParameter=Yes}" />

                <!--  No Button  -->
                <Button
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Command="{Binding NoCommand}"
                    Content="No"
                    Style="{StaticResource DarkButtonStyle}"
                    ToolTip="Confirm no"
                    Visibility="{Binding Buttons, Converter={StaticResource MessageBoxButtonToVisibilityConverter}, ConverterParameter=No}" />

                <!--  Cancel Button  -->
                <Button
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    Style="{StaticResource DarkButtonStyle}"
                    ToolTip="Cancel action"
                    Visibility="{Binding Buttons, Converter={StaticResource MessageBoxButtonToVisibilityConverter}, ConverterParameter=Cancel}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
