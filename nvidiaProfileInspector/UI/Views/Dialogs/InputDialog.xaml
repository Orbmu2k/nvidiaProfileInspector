<Window
    x:Class="nvidiaProfileInspector.UI.Views.Dialogs.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:nvidiaProfileInspector.UI.Controls"
    xmlns:vm="clr-namespace:nvidiaProfileInspector.UI.ViewModels"
    Title="{Binding Title}"
    Width="500"
    Height="Auto"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Style="{StaticResource DarkDialogWindowStyle}"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar (Draggable Area)  -->
        <Border
            Grid.Row="0"
            Padding="24,12,0,0"
            Background="Transparent">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="{Binding Title}" />

                <StackPanel
                    Grid.Column="1"
                    Margin="0,-12,0,0"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button
                        Click="Cancel_Click"
                        Style="{StaticResource CloseWindowButtonStyle}"
                        ToolTip="Close">
                        <Path
                            Width="10"
                            Height="10"
                            Data="{StaticResource IconClose}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                FontSize="14"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Text="{Binding Prompt}"
                TextWrapping="Wrap" />

            <controls:PlaceholderClearTextBox
                x:Name="InputTextBox"
                Grid.Row="1"
                Margin="0,0,0,4"
                VerticalAlignment="Center"
                Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                Validation.ErrorTemplate="{x:Null}" />

            <!--  Validation Error Display  -->
            <TextBlock
                Grid.Row="2"
                Height="16"
                Margin="0,4,0,12"
                HorizontalAlignment="Left"
                FontSize="12"
                Foreground="{DynamicResource ErrorBrush}"
                Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=InputTextBox}"
                TextTrimming="CharacterEllipsis" />

            <!--  Action Area  -->
            <Button
                x:Name="BrowseButton"
                Grid.Row="3"
                Margin="0,0,0,0"
                Padding="12,6"
                HorizontalAlignment="Left"
                Click="BrowseButton_Click"
                Style="{StaticResource DarkButtonStyle}"
                ToolTip="Browse for application absolute path"
                Visibility="{Binding AllowBrowse, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Data="{DynamicResource IconFolder}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                    <TextBlock VerticalAlignment="Center" Text="Browse absolute path..." />
                </StackPanel>
            </Button>
        </Grid>

        <!--  Footer / Buttons  -->
        <Border
            Grid.Row="2"
            Padding="24"
            Background="{DynamicResource Layer2BackgroundBrush}"
            CornerRadius="0,0,8,8">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Content="Cancel"
                    Style="{StaticResource DarkButtonStyle}"
                    ToolTip="Cancel and close" />
                <Button
                    MinWidth="80"
                    Click="OK_Click"
                    Content="OK"
                    IsEnabled="{Binding CanSubmit}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTip="Confirm and save" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
