<Window
    x:Class="nvidiaProfileInspector.UI.Views.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="508"
    Height="187"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowActivated="False"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Styles/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation
                        Storyboard.TargetName="PulseRing"
                        Storyboard.TargetProperty="Opacity"
                        From="0.42"
                        To="0.08"
                        Duration="0:0:1.6"
                        AutoReverse="True" />
                    <DoubleAnimation
                        Storyboard.TargetName="PulseRingScale"
                        Storyboard.TargetProperty="ScaleX"
                        From="0.88"
                        To="1.1"
                        Duration="0:0:1.6"
                        AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="PulseRingScale"
                        Storyboard.TargetProperty="ScaleY"
                        From="0.88"
                        To="1.1"
                        Duration="0:0:1.6"
                        AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="SpinnerArc"
                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                        From="0"
                        To="360"
                        Duration="0:0:1.25" />
                    <DoubleAnimation
                        Storyboard.TargetName="ScanGlow"
                        Storyboard.TargetProperty="X"
                        From="-0.35"
                        To="1.2"
                        Duration="0:0:1.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="StatusDot"
                        Storyboard.TargetProperty="Opacity"
                        From="0.35"
                        To="1"
                        Duration="0:0:0.7"
                        AutoReverse="True" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border
        Padding="1"
        Background="{DynamicResource ControlBorderBrush}"
        CornerRadius="8"
        SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="28"
                Direction="270"
                Opacity="0.45"
                ShadowDepth="10"
                Color="#000000" />
        </Border.Effect>

        <Border
            Background="{DynamicResource TitleBarPopupBackgroundBrush}"
            CornerRadius="7"
            ClipToBounds="True">
            <Grid>

                <Rectangle
                    Width="180"
                    HorizontalAlignment="Left"
                    Opacity="0.28">
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="ScanGlow" X="-180" />
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Grid Margin="34,30,34,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="118" Height="118" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Ellipse
                            x:Name="PulseRing"
                            Stroke="{DynamicResource NvidiaGreenBrush}"
                            Opacity="0.55"
                            StrokeThickness="2"
                            RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="PulseRingScale" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse
                            Margin="9"
                            Stroke="{DynamicResource NvidiaGreenBrush}"
                            Opacity="0.28"
                            StrokeThickness="1" />
                        <Path
                            Data="{StaticResource IconInspectorApp}"
                            Fill="{DynamicResource NvidiaGreenBrush}"
                            Stretch="Uniform" Margin="23,26,28,25">
                            <Path.Effect>
                                <DropShadowEffect
                                    BlurRadius="14"
                                    Direction="0"
                                    Opacity="0.38"
                                    ShadowDepth="0"
                                    Color="#76B900" />
                            </Path.Effect>
                        </Path>
                        <Ellipse
                            x:Name="SpinnerArc"
                            Width="104"
                            Height="104"
                            Stroke="{DynamicResource NvidiaGreenBrush}"
                            Opacity="0.7"
                            StrokeDashArray="28 84"
                            StrokeThickness="4"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round"
                            RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="21"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TitleBrush}"
                            Text="NVIDIA PROFILE INSPECTOR" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="Preparing driver profiles and settings..." />

                        <Grid Margin="0,28,0,0" Height="2">
                            <Border Background="{DynamicResource Layer3BackgroundBrush}" CornerRadius="3" />
                        </Grid>

                        <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                            <Ellipse
                                x:Name="StatusDot"
                                Width="7"
                                Height="7"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Fill="{DynamicResource NvidiaGreenBrush}" />
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="Loading application" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
