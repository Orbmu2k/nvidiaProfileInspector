<Window
    x:Class="nvidiaProfileInspector.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:nvidiaProfileInspector.UI.Behaviors"
    xmlns:controls="clr-namespace:nvidiaProfileInspector.UI.Controls"
    xmlns:converters="clr-namespace:nvidiaProfileInspector.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="clr-namespace:nvidiaProfileInspector.Common.Helper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:nvidiaProfileInspector.UI.ViewModels"
    Title="NVIDIA Profile Inspector"
    Width="1190"
    Height="750"
    MinWidth="1000"
    MinHeight="450"
    d:DataContext="{x:Static vm:DesignTimeData.MainViewModel}"
    Background="Transparent"
    Closing="Window_Closing"
    Cursor="Hand"
    Loaded="Window_Loaded"
    Style="{StaticResource DarkWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">


    <Window.InputBindings>
        <KeyBinding
            Key="F"
            Command="{Binding FocusFilterCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="S"
            Command="{Binding ApplyCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="R"
            Command="{Binding RefreshCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="Escape" Command="{Binding ClearFilterCommand}" />
        <KeyBinding
            Key="D"
            Command="{Binding ToggleDevModeCommand}"
            Modifiers="Ctrl+Alt" />
    </Window.InputBindings>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header/Title  -->
            <RowDefinition Height="Auto" />
            <!--  Command Bar  -->
            <RowDefinition Height="Auto" />
            <!--  Status/Applications  -->
            <RowDefinition Height="*" />
            <!--  Settings List  -->
            <RowDefinition Height="Auto" />
            <!--  Description  -->
            <RowDefinition Height="Auto" />
            <!--  Footer/Progress  -->
        </Grid.RowDefinitions>

        <!--  Header / Title Bar  -->
        <controls:TitleBar
            x:Name="AppTitleBar"
            Title=""
            Grid.Row="0"
            Background="{DynamicResource TitleBarBackdropBrush}"
            Cursor=""
            TitleFontSize="16"
            TitleForeground="{DynamicResource TitleBrush}">
            <controls:TitleBar.Resources>
                <SolidColorBrush x:Key="Layer1BackgroundBrush" Color="{DynamicResource TitleBarPopupBackgroundColor}" />
                <SolidColorBrush x:Key="Layer2BackgroundBrush" Color="{DynamicResource TitleBarControlBackgroundColor}" />
                <SolidColorBrush x:Key="Layer3BackgroundBrush" Color="{DynamicResource TitleBarControlHoverBackgroundColor}" />
                <SolidColorBrush x:Key="ControlBorderBrush" Color="{DynamicResource TitleBarControlBorderColor}" />
                <SolidColorBrush x:Key="ControlBorderHoverBrush" Color="{DynamicResource TitleBarControlBorderHoverColor}" />
            </controls:TitleBar.Resources>

            <controls:TitleBar.IconContent>
                <Path
                    Width="20"
                    Height="20"
                    Data="{StaticResource IconInspectorApp}"
                    Fill="{DynamicResource NvidiaGreenBrush}"
                    Stretch="Uniform" />
            </controls:TitleBar.IconContent>

            <controls:TitleBar.LeftContent>
                <StackPanel Margin="12,0,0,0" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TitleBrush}"
                        Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <!--  Version (static, when no update)  -->
                    <TextBlock
                        Margin="8,3,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="{Binding VersionText}"
                        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                    <!--  Version as link (when update available)  -->
                    <Button
                        Margin="8,3,0,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ShowAboutCommand}"
                        Cursor="Hand"
                        ToolTip="New version available — click for details"
                        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock
                                    x:Name="txt"
                                    FontSize="11"
                                    Foreground="{DynamicResource NvidiaGreenBrush}"
                                    Text="{Binding VersionText}"
                                    TextDecorations="Underline" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="txt" Property="Opacity" Value="0.7" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </controls:TitleBar.LeftContent>

            <controls:TitleBar.CenterContent>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <!--  Global Profile Button  -->
                    <Button
                        x:Name="GlobalProfileButton"
                        Margin="0,0,8,0"
                        Command="{Binding NavigateToGlobalCommand}"
                        Style="{StaticResource HeaderIconButtonStyle}"
                        ToolTip="Navigate to Global Profile">
                        <Path
                            Width="18"
                            Height="18"
                            Data="{DynamicResource IconGlobe}"
                            Fill="{DynamicResource AccentBrush}"
                            Stretch="Uniform" />
                    </Button>

                    <!--  Profile Selector  -->
                    <controls:SearchableComboBox
                        x:Name="ProfileCombo"
                        Width="400"
                        Height="32"
                        Margin="0,0,0,0"
                        IsEditable="False"
                        IsSynchronizedWithCurrentItem="False"
                        ItemsSource="{Binding ProfileNames}"
                        MaxDropDownHeight="500"
                        Placeholder="Search profiles..."
                        SelectedValue="{Binding CurrentProfile}"
                        SelectedValuePath="ProfileName"
                        SyncSelectedItemToText="True">
                        <controls:SearchableComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ProfileListItem}">
                                <Grid ToolTip="{Binding ProfileTypeLabel}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource TextSecondaryBrush}"
                                        Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value="{DynamicResource IconNvidia}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGlobal}" Value="True">
                                                        <Setter Property="Data" Value="{DynamicResource IconGlobe}" />
                                                        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsUserDefined}" Value="True">
                                                        <Setter Property="Data" Value="{DynamicResource IconUser}" />
                                                        <Setter Property="Fill" Value="{DynamicResource NvidiaGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="{Binding ProfileName}" />
                                </Grid>
                            </DataTemplate>
                        </controls:SearchableComboBox.ItemTemplate>
                    </controls:SearchableComboBox>

                    <!--  Modified Profiles Selector  -->
                    <controls:SearchableComboBox
                        x:Name="ModifiedProfilesCombo"
                        Margin="8,0,0,0"
                        ItemsSource="{Binding ModifiedProfiles}"
                        MaxDropDownHeight="500"
                        Placeholder="Search modified profiles..."
                        PreviewKeyDown="ModifiedProfilesCombo_PreviewKeyDown"
                        SelectionChanged="ModifiedProfilesCombo_SelectionChanged"
                        Style="{DynamicResource IconSearchableComboBoxStyle}"
                        SyncSelectedItemToText="True"
                        ToolTip="View Modified Profiles">
                        <controls:SearchableComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ModifiedProfileItem}">
                                <Grid ToolTip="{Binding ProfileTypeLabel}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource TextSecondaryBrush}"
                                        Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value="{DynamicResource IconNvidia}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUserDefined}" Value="True">
                                                        <Setter Property="Data" Value="{DynamicResource IconUser}" />
                                                        <Setter Property="Fill" Value="{DynamicResource NvidiaGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="{Binding ProfileName}" />
                                </Grid>
                            </DataTemplate>
                        </controls:SearchableComboBox.ItemTemplate>
                    </controls:SearchableComboBox>
                </StackPanel>
            </controls:TitleBar.CenterContent>
            <controls:TitleBar.RightContent>
                <StackPanel Orientation="Horizontal">
                    <Grid>
                        <Button
                            x:Name="AppearanceButton"
                            Width="32"
                            Height="32"
                            Margin="4,0"
                            Padding="0"
                            Background="{DynamicResource Layer2BackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            Command="{Binding ToggleAppearanceMenuCommand}"
                            Cursor="Hand"
                            ToolTip="Appearance">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4"
                                        SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ControlBorderHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsAppearanceMenuOpen}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ControlBorderHoverBrush}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Path
                                Width="18"
                                Height="18"
                                Data="{DynamicResource IconTheme}"
                                Fill="{DynamicResource TextSecondaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Popup
                            x:Name="AppearancePopup"
                            AllowsTransparency="True"
                            HorizontalOffset="-68"
                            IsOpen="{Binding IsAppearanceMenuOpen, Mode=TwoWay}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=AppearanceButton}"
                            StaysOpen="False"
                            VerticalOffset="4">
                            <Border
                                Margin="8,0,8,8"
                                Padding="8"
                                Background="{DynamicResource Layer2BackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="16"
                                        Direction="270"
                                        Opacity="0.25"
                                        ShadowDepth="4" />
                                </Border.Effect>
                                <StackPanel Width="168">
                                    <!--  Theme Section  -->
                                    <TextBlock
                                        Margin="6,4,6,4"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="THEME" />
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetThemeCommand}"
                                        CommandParameter="Dark"
                                        Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsDarkTheme, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Dark" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetThemeCommand}"
                                        CommandParameter="Light"
                                        Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsDarkTheme, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Light" />
                                        </StackPanel>
                                    </Button>
                                    <!--  Separator  -->
                                    <Border
                                        Height="1"
                                        Margin="6,6"
                                        Background="{DynamicResource ControlBorderBrush}" />
                                    <!--  Density Section  -->
                                    <TextBlock
                                        Margin="6,4,6,4"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="DENSITY" />
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetDensityCommand}"
                                        CommandParameter="Modern"
                                        Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsCompactDensity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Modern" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetDensityCommand}"
                                        CommandParameter="Compact"
                                        Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsCompactDensity, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Compact" />
                                        </StackPanel>
                                    </Button>
                                    <Border
                                        Height="1"
                                        Margin="6,6"
                                        Background="{DynamicResource ControlBorderBrush}" />
                                    <TextBlock
                                        Margin="6,4,6,4"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="BACKDROP" />
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetBackdropModeCommand}"
                                        CommandParameter="Default"
                                        Cursor="Hand"
                                        Visibility="{Binding IsWindows10, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsBackdropGlass, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Glass" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetBackdropModeCommand}"
                                        CommandParameter="MainWindow"
                                        Cursor="Hand"
                                        Visibility="{Binding IsWindows11, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsBackdropMica, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Mica" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetBackdropModeCommand}"
                                        CommandParameter="Tabbed"
                                        Cursor="Hand"
                                        Visibility="{Binding IsWindows11, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsBackdropMicaVariant, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Mica Variant" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetBackdropModeCommand}"
                                        CommandParameter="Acrylic"
                                        Cursor="Hand"
                                        Visibility="{Binding IsWindows11, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsBackdropAcrylic, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Acrylic" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Margin="0,1"
                                        Padding="6,5"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding SetBackdropModeCommand}"
                                        CommandParameter="Disabled"
                                        Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Layer3BackgroundBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <Border
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="7">
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{DynamicResource NvidiaGreenBrush}"
                                                    Visibility="{Binding IsBackdropDisabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="Disabled" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button
                        Margin="4,0"
                        Command="{Binding ShowAboutCommand}"
                        Style="{StaticResource HeaderIconButtonStyle}"
                        ToolTip="About">
                        <Grid>
                            <Path
                                Width="18"
                                Height="18"
                                Data="{DynamicResource IconInfo}"
                                Fill="{DynamicResource TextSecondaryBrush}"
                                Stretch="Uniform" />
                            <!--  Update Badge  -->
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,-2,-2,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{DynamicResource NvidiaGreenBrush}"
                                BorderBrush="{DynamicResource WindowBackgroundBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </controls:TitleBar.RightContent>
        </controls:TitleBar>

        <Border
            Grid.Row="1"
            Grid.RowSpan="5"
            Background="{DynamicResource Layer1BackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Command Bar  -->
                <Border
                    Grid.Row="0"
                    Padding="16,8"
                    Background="{DynamicResource Layer2BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Cursor=""
                            Orientation="Horizontal">
                            <controls:ActionBarButton
                                Command="{Binding RestoreProfileCommand}"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconNvidia}"
                                Text="Defaults"
                                ToolTip="Restore profile to NVIDIA default settings" />

                            <controls:ActionBarButton
                                Command="{Binding CreateProfileCommand}"
                                Cursor="Hand"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconAdd}"
                                Text="New"
                                ToolTip="Create a new profile" />

                            <controls:ActionBarButton
                                Command="{Binding DeleteProfileCommand}"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconDelete}"
                                Text="Delete"
                                ToolTip="Delete the current profile" />

                            <controls:ActionBarButton
                                Command="{Binding CopySettingsCommand}"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconCopy}"
                                Text="Copy"
                                ToolTip="Copy settings to clipboard" />

                            <controls:ActionBarButton
                                Command="{Binding OpenBitEditorCommand}"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconBitEditor}"
                                Text="Bit Editor"
                                ToolTip="Open the Bit Value Editor" />

                            <Separator Style="{StaticResource ToolBarSeparatorStyle}" />

                            <controls:ActionBarButton
                                x:Name="ExportButton"
                                Click="ExportButton_Click"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconExport}"
                                Text="Export"
                                ToolTip="Export profiles to file" />

                            <controls:ActionBarButton
                                x:Name="ImportButton"
                                Click="ImportButton_Click"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconImport}"
                                Text="Import"
                                ToolTip="Import profiles from file" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <controls:ActionBarToggleButton
                                IconPath="{DynamicResource IconLab}"
                                IsChecked="{Binding ShowScannedUnknownSettings}"
                                Text="Lab"
                                ToggledColor="{DynamicResource ErrorBrush}"
                                ToolTip="Show unknown settings from NVIDIA predefined profiles" />

                            <Separator Style="{StaticResource ToolBarSeparatorStyle}" />

                            <controls:ActionBarButton
                                Command="{Binding RefreshCommand}"
                                IconFill="{DynamicResource TextSecondaryBrush}"
                                IconPath="{DynamicResource IconRefresh}"
                                Text="Refresh"
                                ToolTip="Refresh all profiles" />

                            <controls:ActionBarButton
                                Command="{Binding RefreshCurrentProfileCommand}"
                                IconPath="{DynamicResource IconRestore}"
                                Text="Reset"
                                ToolTip="Reset current profile changes">
                                <controls:ActionBarButton.Style>
                                    <Style BasedOn="{StaticResource {x:Type controls:ActionBarButton}}" TargetType="controls:ActionBarButton">
                                        <Setter Property="IconFill" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="TextForeground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPendingChanges}" Value="True">
                                                <Setter Property="IconFill" Value="{DynamicResource NvidiaGreenBrush}" />
                                                <Setter Property="TextForeground" Value="{DynamicResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:ActionBarButton.Style>
                            </controls:ActionBarButton>

                            <controls:ActionBarButton
                                Command="{Binding ApplyCommand}"
                                Cursor="Hand"
                                FontWeight="Bold"
                                IconPath="{DynamicResource IconApply}"
                                Text="Apply Changes"
                                TextFontSize="11"
                                ToolTip="Apply all changes and save">
                                <controls:ActionBarButton.Style>
                                    <Style BasedOn="{StaticResource {x:Type controls:ActionBarButton}}" TargetType="controls:ActionBarButton">
                                        <Setter Property="IconFill" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="TextForeground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPendingChanges}" Value="True">
                                                <Setter Property="IconFill" Value="{DynamicResource NvidiaGreenBrush}" />
                                                <Setter Property="TextForeground" Value="{DynamicResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:ActionBarButton.Style>
                            </controls:ActionBarButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Applications Area with Badges  -->
                <Border
                    Grid.Row="1"
                    Padding="16,8"
                    Background="{DynamicResource Layer1BackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding ShowApplicationsArea, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Orientation="Horizontal">
                            <Button
                                Click="AddApplication_Click"
                                Content="Add Application"
                                Style="{StaticResource AddApplicationButtonStyle}"
                                ToolTip="Add a new application to this profile" />
                            <Separator Margin="0,4,0,4" Style="{StaticResource ToolBarSeparatorStyle}" />
                        </StackPanel>

                        <Border
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="12,0,0,0">
                            <ItemsControl ItemsSource="{Binding Applications}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Click="RemoveApplication_Click"
                                            Style="{StaticResource ApplicationChipStyle}"
                                            Tag="{Binding}"
                                            ToolTip="{Binding KeyDisplay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Border>

                <!--  Settings List Area  -->
                <Grid Grid.Row="2" Margin="16,16,16,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Filter Row  -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Search Box with Icon  -->
                        <controls:SearchableTextBox
                            x:Name="FilterTextBox"
                            Grid.Column="0"
                            Placeholder="Search settings..."
                            Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="Search settings by name (Ctrl+F)" />

                        <!--  Setting Types  -->
                        <ComboBox
                            Grid.Column="1"
                            Width="155"
                            Margin="12,0,0,0"
                            SelectedIndex="{Binding FilterTypeIndex}"
                            Style="{StaticResource DarkComboBoxStyle}"
                            ToolTip="Filter settings by type">
                            <ComboBoxItem Content="Common Settings" />
                            <ComboBoxItem Content="Show All Settings" />
                        </ComboBox>
                    </Grid>

                    <!--  Settings ListView  -->
                    <ListView
                        x:Name="SettingsListView"
                        Grid.Row="1"
                        behaviors:ScrollIntoViewForListView.Enable="{Binding ScrollIntoViewEnabled}"
                        ItemsSource="{Binding GroupedSettingsView}"
                        SelectedItem="{Binding SelectedSetting}"
                        Style="{StaticResource DarkListViewStyle}">
                        <ListView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource DarkListViewItemStyle}" TargetType="ListViewItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ModifiedSettingBackgroundBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="GridViewColumnHeader">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="Padding" Value="8,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="GridViewColumnHeader">
                                                    <Border
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                                        BorderThickness="0,0,0,1">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>

                                <GridViewColumn Width="32" Header="">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Path
                                                x:Name="SettingStateIcon"
                                                Width="14"
                                                Height="14"
                                                HorizontalAlignment="Center"
                                                Data="{Binding State, Converter={StaticResource StateToIconConverter}, Mode=OneWay}"
                                                Fill="{Binding State, Converter={StaticResource StateToSettingIconColorConverter}, Mode=OneWay}"
                                                Stretch="Uniform"
                                                ToolTip="{Binding State, Converter={StaticResource StateToTooltipConverter}, Mode=OneWay}" />
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                    <Setter TargetName="SettingStateIcon" Property="Data" Value="{DynamicResource IconUser}" />
                                                    <Setter TargetName="SettingStateIcon" Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Setter TargetName="SettingStateIcon" Property="ToolTip" Value="User-modified Setting" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Width="32" Header="">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Width="20"
                                                Height="20"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Toggle Favorite">
                                                <Path
                                                    Width="14"
                                                    Height="14"
                                                    Data="{StaticResource IconStar}"
                                                    Fill="{Binding IsFavorite, Converter={StaticResource FavoriteToBrushConverter}, Mode=OneWay}"
                                                    Stretch="Uniform" />
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Width="450" Header="SETTING">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                x:Name="SettingNameText"
                                                Margin="12,0"
                                                VerticalAlignment="Center"
                                                Foreground="{Binding State, Converter={StaticResource StateToSettingIconColorConverter}, Mode=OneWay}"
                                                Text="{Binding DisplayName, Mode=OneWay}"
                                                ToolTip="{Binding SettingIdHex, Mode=OneWay}"
                                                ToolTipService.IsEnabled="{Binding DataContext.IsDevMode, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                    <Setter TargetName="SettingNameText" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Width="450" Header="VALUE">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <!--  Display mode: Simple TextBlock (lightweight)  -->
                                                <TextBlock
                                                    x:Name="DisplayText"
                                                    Margin="12,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{Binding State, Converter={StaticResource StateToColorConverter}, Mode=OneWay}"
                                                    Text="{Binding SelectedValue, Mode=OneWay}"
                                                    TextWrapping="NoWrap" />
                                                <!--  Edit mode: Full ComboBox (only for selected row)  -->
                                                <controls:SearchableComboBox
                                                    x:Name="EditComboBox"
                                                    Grid.Column="0"
                                                    Margin="-2,-1,4,-1"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Stretch"
                                                    Cursor=""
                                                    IsEditable="True"
                                                    ItemsSource="{Binding ValueNameItems, Mode=OneWay}"
                                                    MaxDropDownHeight="400"
                                                    Placeholder="Search values..."
                                                    DeferSelectionUntilCommit="True"
                                                    PreserveSelectionOnKeyboardFocus="True"
                                                    SyncSelectedItemToText="False"
                                                    Text="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="Collapsed">
                                                    <controls:SearchableComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path
                                                                    Width="12"
                                                                    Height="12"
                                                                    Margin="0,0,8,0"
                                                                    Data="{Binding Source, Converter={StaticResource SettingMetaSourceToIconConverter}, Mode=OneWay}"
                                                                    Fill="{DynamicResource TextSecondaryBrush}"
                                                                    Stretch="Uniform" />
                                                                <TextBlock
                                                                    Text="{Binding ValueName, Mode=OneWay}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="NoWrap" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </controls:SearchableComboBox.ItemTemplate>
                                                </controls:SearchableComboBox>
                                                <!--  Reset Button  -->
                                                <Button
                                                    x:Name="RestoreButton"
                                                    Grid.Column="1"
                                                    Width="28"
                                                    Height="28"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ResetValueCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="Reset setting to default value"
                                                    Visibility="Collapsed">
                                                    <Path
                                                        Width="14"
                                                        Height="14"
                                                        Data="{DynamicResource IconRestore}"
                                                        Fill="{DynamicResource NvidiaGreenBrush}"
                                                        Stretch="Uniform" />
                                                </Button>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                    <Setter TargetName="DisplayText" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                    <Setter TargetName="DisplayText" Property="Visibility" Value="Collapsed" />
                                                    <Setter TargetName="EditComboBox" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsUserDefined}" Value="True" />
                                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="RestoreButton" Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                    <Setter TargetName="RestoreButton" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="RestoreButton" Property="ToolTip" Value="Reset setting to original value" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Width="200" Header="HEX">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                x:Name="HexValueText"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="Consolas"
                                                Foreground="{Binding State, Converter={StaticResource StateToColorConverter}, Mode=OneWay}"
                                                Text="{Binding ValueRaw, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTip="{Binding ValueRaw, Mode=OneWay}" />
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                    <Setter TargetName="HexValueText" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>

                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style BasedOn="{StaticResource ListViewGroupHeaderStyle}" TargetType="GroupItem" />
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </ListView.GroupStyle>
                    </ListView>
                </Grid>

                <!--  Setting Description  -->
                <Border
                    Grid.Row="3"
                    Margin="16,0,16,16"
                    Padding="12"
                    Background="{DynamicResource Layer3BackgroundBrush}"
                    CornerRadius="8"
                    Visibility="{Binding SettingDescription, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{DynamicResource NvidiaGreenBrush}"
                            Text="DESCRIPTION" />
                        <TextBox
                            MaxHeight="80"
                            Padding="0"
                            AcceptsReturn="True"
                            Background="Transparent"
                            BorderThickness="0"
                            IsReadOnly="True"
                            Style="{StaticResource DarkTextBoxStyle}"
                            Text="{Binding SettingDescription, Mode=OneWay}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <!--  Footer / Progress  -->
                <Border
                    Grid.Row="4"
                    Padding="8,8"
                    Background="{DynamicResource Layer1BackgroundBrush}">
                    <Grid>
                        <ProgressBar
                            VerticalAlignment="Center"
                            Maximum="100"
                            Style="{StaticResource DarkProgressBarStyle}"
                            Value="{Binding ScanProgress}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!--  Snackbar Notifications  -->
        <controls:NotificationSnackbar
            Grid.RowSpan="6"
            IsActive="{Binding IsSnackbarActive}"
            Message="{Binding SnackbarMessage}"
            Type="{Binding SnackbarType}" />

    </Grid>


</Window>
