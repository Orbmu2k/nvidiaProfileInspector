<Window
    x:Class="nvidiaProfileInspector.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:nvidiaProfileInspector.UI.Behaviors"
    xmlns:controls="clr-namespace:nvidiaProfileInspector.UI.Controls"
    xmlns:converters="clr-namespace:nvidiaProfileInspector.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="clr-namespace:nvidiaProfileInspector.Common.Helper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:nvidiaProfileInspector.UI.ViewModels"
    Title="NVIDIA Profile Inspector"
    Width="1190"
    Height="750"
    MinWidth="1000"
    MinHeight="450"
    d:DataContext="{x:Static vm:DesignTimeData.MainViewModel}"
    AllowDrop="True"
    Closing="Window_Closing"
    Cursor="Hand"
    Drop="Window_Drop"
    Loaded="Window_Loaded"
    Style="{StaticResource DarkWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">


    <Window.InputBindings>
        <KeyBinding
            Key="F"
            Command="{Binding FocusFilterCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="S"
            Command="{Binding ApplyCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="R"
            Command="{Binding RefreshCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="Escape" Command="{Binding ClearFilterCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header/Title  -->
            <RowDefinition Height="Auto" />
            <!--  Command Bar  -->
            <RowDefinition Height="Auto" />
            <!--  Status/Applications  -->
            <RowDefinition Height="*" />
            <!--  Settings List  -->
            <RowDefinition Height="Auto" />
            <!--  Description  -->
            <RowDefinition Height="Auto" />
            <!--  Footer/Progress  -->
        </Grid.RowDefinitions>

        <!--  Header / Title Bar  -->
        <controls:TitleBar
            Title="NVIDIA Profile Inspector"
            Grid.Row="0"
            Cursor=""
            TitleFontSize="16"
            TitleForeground="{DynamicResource TitleBrush}">

            <controls:TitleBar.IconContent>
                <Path
                    Width="20"
                    Height="20"
                    Data="{StaticResource IconInspectorApp}"
                    Fill="{DynamicResource NvidiaGreenBrush}"
                    Stretch="Uniform" />
            </controls:TitleBar.IconContent>

            <controls:TitleBar.CenterContent>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <!--  Global Profile Button  -->
                    <Button
                        x:Name="GlobalProfileButton"
                        Margin="0,0,8,0"
                        Command="{Binding NavigateToGlobalCommand}"
                        Style="{StaticResource HeaderIconButtonStyle}"
                        ToolTip="Navigate to Global Profile">
                        <Path
                            Width="18"
                            Height="18"
                            Data="{DynamicResource IconGlobe}"
                            Fill="{DynamicResource AccentBrush}"
                            Stretch="Uniform" />
                    </Button>

                    <!--  Profile Selector  -->
                    <controls:SearchableComboBox
                        x:Name="ProfileCombo"
                        Width="400"
                        Height="32"
                        Margin="0,0,0,0"
                        IsEditable="False"
                        IsSynchronizedWithCurrentItem="False"
                        ItemsSource="{Binding ProfilesView}"
                        MaxDropDownHeight="500"
                        Placeholder="Search profiles..."
                        SelectedItem="{Binding CurrentProfile}" />

                    <!--  Modified Profiles Selector  -->
                    <controls:SearchableComboBox
                        x:Name="ModifiedProfilesCombo"
                        Margin="8,0,0,0"
                        ItemsSource="{Binding ModifiedProfilesView}"
                        MaxDropDownHeight="500"
                        Placeholder="Search modified profiles..."
                        SelectionChanged="ModifiedProfilesCombo_SelectionChanged"
                        Style="{DynamicResource IconSearchableComboBoxStyle}"
                        ToolTip="View Modified Profiles" />
                </StackPanel>
            </controls:TitleBar.CenterContent>
            <controls:TitleBar.RightContent>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource HeaderIconButtonStyle}"
                        ToolTip="Change Theme"
                        Margin="4,0">
                        <Path
                            Width="18"
                            Height="18"
                            Data="{DynamicResource IconTheme}"
                            Fill="{DynamicResource TextSecondaryBrush}"
                            Stretch="Uniform" />
                    </Button>
                    <Button
                        Command="{Binding ShowAboutCommand}"
                        Style="{StaticResource HeaderIconButtonStyle}"
                        ToolTip="About"
                        Margin="4,0">
                        <Grid>
                            <Path
                                Width="18"
                                Height="18"
                                Data="{DynamicResource IconInfo}"
                                Fill="{DynamicResource TextSecondaryBrush}"
                                Stretch="Uniform" />
                            <!--  Update Badge  -->
                            <Border
                                Width="8"
                                Height="8"
                                Margin="0,-2,-2,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{DynamicResource NvidiaGreenBrush}"
                                BorderBrush="{DynamicResource WindowBackgroundBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </controls:TitleBar.RightContent>
        </controls:TitleBar>

        <!--  Command Bar  -->
        <Border
            Grid.Row="1"
            Padding="16,8"
            Background="{DynamicResource Layer2BackgroundBrush}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Cursor=""
                    Orientation="Horizontal">
                    <!--  Profile Actions  -->
                    <controls:ActionBarButton
                        Command="{Binding RestoreProfileCommand}"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconNvidia}"
                        Text="Defaults"
                        ToolTip="Restore profile to NVIDIA default settings" />

                    <controls:ActionBarButton
                        Command="{Binding CreateProfileCommand}"
                        Cursor="Hand"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconAdd}"
                        Text="New"
                        ToolTip="Create a new profile" />

                    <controls:ActionBarButton
                        Command="{Binding DeleteProfileCommand}"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconDelete}"
                        Text="Delete"
                        ToolTip="Delete the current profile" />

                    <controls:ActionBarButton
                        Command="{Binding CopySettingsCommand}"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconCopy}"
                        Text="Copy"
                        ToolTip="Copy settings to clipboard" />

                    <controls:ActionBarButton
                        Command="{Binding OpenBitEditorCommand}"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconBitEditor}"
                        Text="Bit Editor"
                        ToolTip="Open the Bit Value Editor" />



                    <Separator Style="{StaticResource ToolBarSeparatorStyle}" />

                    <!--  Data Actions  -->
                    <controls:ActionBarButton
                        x:Name="ExportButton"
                        Click="ExportButton_Click"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconExport}"
                        Text="Export"
                        ToolTip="Export profiles to file" />

                    <controls:ActionBarButton
                        x:Name="ImportButton"
                        Click="ImportButton_Click"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconImport}"
                        Text="Import"
                        ToolTip="Import profiles from file" />



                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">



                    <controls:ActionBarToggleButton
                        IconPath="{DynamicResource IconLab}"
                        IsChecked="{Binding ShowScannedUnknownSettings}"
                        ToggledColor="{DynamicResource ErrorBrush}"
                        Text="Lab"
                        ToolTip="Show unknown settings from NVIDIA predefined profiles" />


                    <Separator Style="{StaticResource ToolBarSeparatorStyle}" />


                    <controls:ActionBarButton
                        Command="{Binding RefreshCommand}"
                        IconFill="{DynamicResource TextSecondaryBrush}"
                        IconPath="{DynamicResource IconRefresh}"
                        Text="Refresh"
                        ToolTip="Refresh all profiles" />

                    <controls:ActionBarButton
                        Command="{Binding ApplyCommand}"
                        Cursor="Hand"
                        FontWeight="Bold"
                        IconFill="{DynamicResource NvidiaGreenBrush}"
                        IconPath="{DynamicResource IconApply}"
                        Text="Apply Changes"
                        TextFontSize="11"
                        TextForeground="{DynamicResource TextPrimaryBrush}"
                        ToolTip="Apply all changes and save" />
                </StackPanel>
            </Grid>
        </Border>
        <!--  Applications Area with Badges  -->
        <Border
            Grid.Row="2"
            Padding="16,8"
            Background="{DynamicResource Layer1BackgroundBrush}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="0,0,0,1"
            Visibility="{Binding ShowApplicationsArea, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>


                <StackPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Orientation="Horizontal">
                    <Button
                        Click="AddApplication_Click"
                        Content="Add Application"
                        Style="{StaticResource AddApplicationButtonStyle}"
                        ToolTip="Add a new application to this profile" />
                    <Separator Margin="0,4,0,4" Style="{StaticResource ToolBarSeparatorStyle}" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="12,0,0,0">
                    <ItemsControl ItemsSource="{Binding Applications}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Click="RemoveApplication_Click"
                                    Style="{StaticResource ApplicationChipStyle}"
                                    Tag="{Binding}"
                                    ToolTip="{Binding Key}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>
        </Border>



        <!--  Settings List Area  -->
        <Grid Grid.Row="3" Margin="16,16,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Filter Row  -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Search Box with Icon  -->
                <controls:SearchableTextBox
                    x:Name="FilterTextBox"
                    Grid.Column="0"
                    Placeholder="Search settings..."
                    Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Search settings by name (Ctrl+F)" />

                <!--  Setting Types  -->
                <ComboBox
                    Grid.Column="1"
                    Width="155"
                    Margin="12,0,0,0"
                    SelectedIndex="{Binding FilterTypeIndex}"
                    Style="{StaticResource DarkComboBoxStyle}"
                    ToolTip="Filter settings by type">
                    <ComboBoxItem Content="Common Settings" />
                    <ComboBoxItem Content="Show All Settings" />
                </ComboBox>
            </Grid>

            <!--  Settings ListView  -->
            <ListView
                x:Name="SettingsListView"
                Grid.Row="1"
                behaviors:ScrollIntoViewForListView.Enable="{Binding ScrollIntoViewEnabled}"
                ItemContainerStyle="{StaticResource DarkListViewItemStyle}"
                ItemsSource="{Binding GroupedSettingsView, IsAsync=True}"
                SelectedItem="{Binding SelectedSetting}"
                Style="{StaticResource DarkListViewStyle}">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                <Setter Property="Padding" Value="8,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="0,0,0,1">
                                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>

                        <GridViewColumn Width="32" Header="">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Path
                                        Width="14"
                                        Height="14"
                                        HorizontalAlignment="Center"
                                        Data="{Binding State, Converter={StaticResource StateToIconConverter}, Mode=OneWay}"
                                        Fill="{Binding State, Converter={StaticResource StateToSettingIconColorConverter}, Mode=OneWay}"
                                        Stretch="Uniform"
                                        ToolTip="{Binding State, Converter={StaticResource StateToTooltipConverter}, Mode=OneWay}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="32" Header="">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="20"
                                        Height="20"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Toggle Favorite">
                                        <Path
                                            Width="14"
                                            Height="14"
                                            Data="{StaticResource IconStar}"
                                            Fill="{Binding IsFavorite, Converter={StaticResource FavoriteToBrushConverter}, Mode=OneWay}"
                                            Stretch="Uniform" />
                                    </Button>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="450" Header="SETTING">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        Foreground="{Binding State, Converter={StaticResource StateToSettingIconColorConverter}, Mode=OneWay}"
                                        Text="{Binding DisplayName, Mode=OneWay}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="450" Header="VALUE">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!--  Display mode: Simple TextBlock (lightweight)  -->
                                        <TextBlock
                                            x:Name="DisplayText"
                                            Margin="12,0"
                                            VerticalAlignment="Center"
                                            Foreground="{Binding State, Converter={StaticResource StateToColorConverter}, Mode=OneWay}"
                                            Text="{Binding SelectedValue, Mode=OneWay}" />
                                        <!--  Edit mode: Full ComboBox (only for selected row)  -->
                                        <controls:SearchableComboBox
                                            x:Name="EditComboBox"
                                            Grid.Column="0"
                                            Margin="-2,-1,4,-1"
                                            Padding="8,4"
                                            HorizontalAlignment="Stretch"
                                            IsEditable="True"
                                            ItemsSource="{Binding ValueNameItems, Mode=OneWay}"
                                            MaxDropDownHeight="400"
                                            Placeholder="Search values..."
                                            Text="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Visibility="Collapsed">
                                            <controls:SearchableComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path
                                                            Width="12"
                                                            Height="12"
                                                            Margin="0,0,8,0"
                                                            Data="{Binding Source, Converter={StaticResource SettingMetaSourceToIconConverter}, Mode=OneWay}"
                                                            Fill="{DynamicResource TextSecondaryBrush}"
                                                            Stretch="Uniform" />
                                                        <TextBlock Text="{Binding ValueName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </controls:SearchableComboBox.ItemTemplate>
                                        </controls:SearchableComboBox>
                                        <!--  Reset Button  -->
                                        <Button
                                            x:Name="RestoreButton"
                                            Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.ResetValueCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="Reset setting to default value"
                                            Visibility="Collapsed">
                                            <Path
                                                Width="14"
                                                Height="14"
                                                Data="{DynamicResource IconRestore}"
                                                Fill="{DynamicResource NvidiaGreenBrush}"
                                                Stretch="Uniform" />
                                        </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                            <Setter TargetName="DisplayText" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="EditComboBox" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsUserDefined}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="104" Header="HEX">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        Foreground="{Binding State, Converter={StaticResource StateToColorConverter}, Mode=OneWay}"
                                        Text="{Binding ValueRaw, Mode=OneWay}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style BasedOn="{StaticResource ListViewGroupHeaderStyle}" TargetType="GroupItem" />
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
        </Grid>

        <!--  Setting Description  -->
        <Border
            Grid.Row="4"
            Margin="16,0,16,16"
            Padding="12"
            Background="{DynamicResource Layer3BackgroundBrush}"
            CornerRadius="8"
            Visibility="{Binding SettingDescription, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="10"
                    FontWeight="Bold"
                    Foreground="{DynamicResource NvidiaGreenBrush}"
                    Text="DESCRIPTION" />
                <TextBox
                    MaxHeight="80"
                    Padding="0"
                    AcceptsReturn="True"
                    Background="Transparent"
                    BorderThickness="0"
                    IsReadOnly="True"
                    Style="{StaticResource DarkTextBoxStyle}"
                    Text="{Binding SettingDescription, Mode=OneWay}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </Border>

        <!--  Footer / Progress  -->
        <Border
            Grid.Row="5"
            Padding="8,8"
            Background="{DynamicResource Layer1BackgroundBrush}">
            <Grid>
                <ProgressBar
                    VerticalAlignment="Center"
                    Maximum="100"
                    Style="{StaticResource DarkProgressBarStyle}"
                    Value="{Binding ScanProgress}" />
            </Grid>
        </Border>

        <!--  Snackbar Notifications  -->
        <controls:NotificationSnackbar
            Grid.RowSpan="6"
            IsActive="{Binding IsSnackbarActive}"
            Message="{Binding SnackbarMessage}"
            Type="{Binding SnackbarType}" />

    </Grid>


</Window>
