<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  Midnight Theme - Deep slate variant inspired by nvidia.com aesthetic  -->
    <!--  Built around modern deep slate/charcoal, high-end typography, and signature NVIDIA Green  -->

    <!--  Base Colors - Distinct from pitch black corporate, utilizing softer, modern slate deeps  -->
    <Color x:Key="WindowBackgroundColor">#0F1115</Color>
    <Color x:Key="Layer1BackgroundColor">#1A1D24</Color>
    <Color x:Key="Layer2BackgroundColor">#262A33</Color>
    <Color x:Key="Layer3BackgroundColor">#353A45</Color>
    <Color x:Key="TitleBarBackgroundColor">#0F1115</Color>
    <Color x:Key="TitleBarBackdropColor">#880F1115</Color>
    <Color x:Key="TitleBarControlBackgroundColor">#D41A1D24</Color>
    <Color x:Key="TitleBarControlHoverBackgroundColor">#EA262A33</Color>
    <Color x:Key="TitleBarControlBorderColor">#88353A45</Color>
    <Color x:Key="TitleBarControlBorderHoverColor">#76B900</Color>
    <Color x:Key="TitleBarPopupBackgroundColor">#F00F1115</Color>

    <!--  Brand Colors -> The Authentic NVIDIA Green  -->
    <Color x:Key="NvidiaGreenColor">#76B900</Color>
    <Color x:Key="NvidiaGreenHoverColor">#8AD400</Color>
    <Color x:Key="NvidiaGreenPressedColor">#659F00</Color>

    <!--  Text Colors - Softer, highly legible off-whites favored in modern web design  -->
    <Color x:Key="TitleColor">#FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#F0F2F5</Color>
    <Color x:Key="TextSecondaryColor">#A8B1C2</Color>
    <Color x:Key="TextDisabledColor">#727A8A</Color>

    <!--  Accent Colors - Distinct Web Blue for Global/User identities to contrast the Nvidia Green  -->
    <Color x:Key="UserAccentColor">#00A1FF</Color>
    <Color x:Key="UserAccentHoverColor">#33B5FF</Color>

    <!--  Control Border Colors - Web-style soft stroke borders  -->
    <Color x:Key="ControlBorderColor">#353A45</Color>
    <Color x:Key="ControlBorderHoverColor">#5B6476</Color>
    <Color x:Key="AccentBorderColor">#76B900</Color>

    <!--  Status Colors - Clean indicators matching web styles  -->
    <Color x:Key="SuccessColor">#76B900</Color>
    <Color x:Key="ErrorColor">#FF4D4D</Color>
    <Color x:Key="WarningColor">#FFB800</Color>
    <Color x:Key="QuestionColor">#33A1FF</Color>
    <Color x:Key="LabColor">#76B900</Color>

    <!--  Brushes  -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="Layer1BackgroundBrush" Color="{StaticResource Layer1BackgroundColor}" />
    <SolidColorBrush x:Key="Layer2BackgroundBrush" Color="{StaticResource Layer2BackgroundColor}" />
    <SolidColorBrush x:Key="Layer3BackgroundBrush" Color="{StaticResource Layer3BackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource TitleBarBackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarBackdropBrush" Color="{StaticResource TitleBarBackdropColor}" />
    <SolidColorBrush x:Key="TitleBarControlBackgroundBrush" Color="{StaticResource TitleBarControlBackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarControlHoverBackgroundBrush" Color="{StaticResource TitleBarControlHoverBackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarControlBorderBrush" Color="{StaticResource TitleBarControlBorderColor}" />
    <SolidColorBrush x:Key="TitleBarControlBorderHoverBrush" Color="{StaticResource TitleBarControlBorderHoverColor}" />
    <SolidColorBrush x:Key="TitleBarPopupBackgroundBrush" Color="{StaticResource TitleBarPopupBackgroundColor}" />

    <!--  Nvidia Green maps correctly across the UI  -->
    <SolidColorBrush x:Key="NvidiaGreenBrush" Color="{StaticResource NvidiaGreenColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource UserAccentColor}" />
    <SolidColorBrush x:Key="UserAccentBrush" Color="{StaticResource UserAccentColor}" />
    <SolidColorBrush x:Key="NvidiaGreenHoverBrush" Color="{StaticResource NvidiaGreenHoverColor}" />
    <SolidColorBrush x:Key="NvidiaGreenPressedBrush" Color="{StaticResource NvidiaGreenPressedColor}" />

    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource TitleColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />

    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}" />
    <SolidColorBrush x:Key="ControlBorderHoverBrush" Color="{StaticResource ControlBorderHoverColor}" />
    <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentBorderColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningTintBrush" Color="#33FFB800" />
    <SolidColorBrush x:Key="QuestionBrush" Color="{StaticResource QuestionColor}" />
    <SolidColorBrush x:Key="LabBrush" Color="{StaticResource LabColor}" />

    <!--  Overlay / Transparency Brushes - White/Slate blends  -->
    <SolidColorBrush x:Key="HighlightOverlayBrush" Color="#15FFFFFF" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#11FFFFFF" />
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#22FFFFFF" />

    <!--  Scrollbar Colors - Soft slate with green hover  -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#66353A45" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#8076B900" />
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#CC76B900" />

    <!--  Special Purpose Brushes  -->
    <SolidColorBrush x:Key="ApplicationRemoveBrush" Color="#262A33" />
    <SolidColorBrush x:Key="ApplicationRemoveForegroundBrush" Color="#FF4D4D" />
    <SolidColorBrush x:Key="ApplicationAddBrush" Color="#262A33" />
    <SolidColorBrush x:Key="ApplicationAddHoverBrush" Color="#76B900" />
    <SolidColorBrush x:Key="ListViewAlternatingRowBrush" Color="#15181E" />
    
    <!--  Modified setting background: Clean slate highlight to avoid muddy olive colors  -->
    <SolidColorBrush x:Key="ModifiedSettingBackgroundBrush" Color="#15FFFFFF" />

</ResourceDictionary>
