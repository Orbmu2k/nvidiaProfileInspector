<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  Clean White Theme - Neutral high-contrast light mode  -->
    <!--  Uses graphite and slate grays for interaction states to align with the lighter variants  -->

    <!--  Base Colors - Ultra clean white with sharp borders  -->
    <Color x:Key="WindowBackgroundColor">#FFFFFF</Color>
    <Color x:Key="Layer1BackgroundColor">#FFFFFF</Color>
    <Color x:Key="Layer2BackgroundColor">#F3F4F6</Color>
    <Color x:Key="Layer3BackgroundColor">#E5E7EB</Color>
    <Color x:Key="TitleBarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="TitleBarBackdropColor">#22FFFFFF</Color>
    <Color x:Key="TitleBarControlBackgroundColor">#FFFFFF</Color>
    <Color x:Key="TitleBarControlHoverBackgroundColor">#F3F4F6</Color>
    <Color x:Key="TitleBarControlBorderColor">#D1D5DB</Color>
    <Color x:Key="TitleBarControlBorderHoverColor">#9CA3AF</Color>
    <Color x:Key="TitleBarPopupBackgroundColor">#FAFFFFFF</Color>

    <!--  Brand Colors - Keep a restrained green for indicators, with neutral grays for interaction states  -->
    <Color x:Key="NvidiaGreenColor">#76B900</Color>
    <Color x:Key="NvidiaGreenHoverColor">#9CA3AF</Color>
    <Color x:Key="NvidiaGreenPressedColor">#6B7280</Color>

    <!--  Text Colors - Deep Graphite for maximum legibility and contrast against white and green  -->
    <Color x:Key="TitleColor">#111827</Color>
    <Color x:Key="TextPrimaryColor">#1F2937</Color>
    <Color x:Key="TextSecondaryColor">#4B5563</Color>
    <Color x:Key="TextDisabledColor">#9CA3AF</Color>

    <!--  Accent Colors - Distinct Web Blue for Global/User identities to contrast the Nvidia Green  -->
    <Color x:Key="UserAccentColor">#0078D4</Color>
    <Color x:Key="UserAccentHoverColor">#0099FF</Color>

    <!--  Control Border Colors - Sharp contrast dividing lines  -->
    <Color x:Key="ControlBorderColor">#D1D5DB</Color>
    <Color x:Key="ControlBorderHoverColor">#9CA3AF</Color>
    <Color x:Key="AccentBorderColor">#9CA3AF</Color>

    <!--  Status Colors - Modern sharp  -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="QuestionColor">#3B82F6</Color>
    <Color x:Key="LabColor">#6B7280</Color>

    <!--  Brushes  -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="Layer1BackgroundBrush" Color="{StaticResource Layer1BackgroundColor}" />
    <SolidColorBrush x:Key="Layer2BackgroundBrush" Color="{StaticResource Layer2BackgroundColor}" />
    <SolidColorBrush x:Key="Layer3BackgroundBrush" Color="{StaticResource Layer3BackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource TitleBarBackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarBackdropBrush" Color="{StaticResource TitleBarBackdropColor}" />
    <SolidColorBrush x:Key="TitleBarControlBackgroundBrush" Color="{StaticResource TitleBarControlBackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarControlHoverBackgroundBrush" Color="{StaticResource TitleBarControlBorderColor}" />
    <SolidColorBrush x:Key="TitleBarControlBorderBrush" Color="{StaticResource TitleBarControlBorderColor}" />
    <SolidColorBrush x:Key="TitleBarControlBorderHoverBrush" Color="{StaticResource TitleBarControlBorderHoverColor}" />
    <SolidColorBrush x:Key="TitleBarPopupBackgroundBrush" Color="{StaticResource TitleBarPopupBackgroundColor}" />

    <!--  Keep the base indicator green while hover and pressed states stay neutral  -->
    <SolidColorBrush x:Key="NvidiaGreenBrush" Color="{StaticResource NvidiaGreenColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource UserAccentColor}" />
    <SolidColorBrush x:Key="UserAccentBrush" Color="{StaticResource UserAccentColor}" />
    <SolidColorBrush x:Key="NvidiaGreenHoverBrush" Color="{StaticResource NvidiaGreenHoverColor}" />
    <SolidColorBrush x:Key="NvidiaGreenPressedBrush" Color="{StaticResource NvidiaGreenPressedColor}" />

    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource TitleColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />

    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}" />
    <SolidColorBrush x:Key="ControlBorderHoverBrush" Color="{StaticResource ControlBorderHoverColor}" />
    <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentBorderColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="QuestionBrush" Color="{StaticResource QuestionColor}" />
    <SolidColorBrush x:Key="LabBrush" Color="{StaticResource LabColor}" />

    <!--  Overlay / Transparency Brushes - Match the Slate light variant  -->
    <SolidColorBrush x:Key="HighlightOverlayBrush" Color="#081A1D21" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#0A1A1D21" />
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#141A1D21" />

    <!--  Scrollbar Colors - Match the Slate light transparency treatment  -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#201A1D21" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#301A1D21" />
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#451A1D21" />

    <!--  Special Purpose Brushes  -->
    <SolidColorBrush x:Key="ApplicationRemoveBrush" Color="#FEF2F2" />
    <SolidColorBrush x:Key="ApplicationRemoveForegroundBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="ApplicationAddBrush" Color="#ECFDF5" />
    <SolidColorBrush x:Key="ApplicationAddHoverBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="ListViewAlternatingRowBrush" Color="#F9FAFB" />
    <!--  Modified setting background: Neutral highlight to match the other light variants  -->
    <SolidColorBrush x:Key="ModifiedSettingBackgroundBrush" Color="#14111827" />

</ResourceDictionary>
